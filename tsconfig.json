{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": false,
    "allowJs": false,
    "skipLibCheck": true,
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "types": ["node", "bun"]
  },
  "include": [
    "lib/config.ts",
    "lib/paths.ts",
    "lib/redact.ts",
    "lib/review.ts",
    "lib/workflow.ts"
  ]
}
